# Cloudflare Environment Variables
# This file documents all required and optional environment variables
# Do not commit real secrets to version control

# ============================================
# CLOUDFLARE PAGES - PRODUCTION
# ============================================

# Clerk Authentication
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=sk_live_...

# Google OAuth (YouTube Integration)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
GOOGLE_OAUTH_REDIRECT_URI=https://tubelinkr.com/api/youtube/oauth/callback

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PRO_PRICE_ID_MONTHLY=price_...
PRO_PRICE_ID_YEARLY=price_...
FOUNDER_PRICE_ID=price_...

# Email (Resend)
RESEND_API_KEY=re_...

# Admin Access
ADMIN_TEST_KEY=your-secure-random-string
ADMIN_EMAIL_ALLOWLIST=robertbolgar@gmail.com

# Rate Limiting (Durable Object Binding)
RATE_LIMITER=rate_limiter

# ============================================
# CLOUDFLARE PAGES - PREVIEW/DEV ONLY
# ============================================

# Admin Set-Pro Endpoint (Preview/Dev Only)
# WARNING: Only enable this in preview/dev environments for testing
# Do NOT enable in production - use Stripe webhook for plan changes
ALLOW_ADMIN_SET_PRO=true

# ============================================
# CLOUDFLARE WORKER (go.tubelinkr.com)
# ============================================

# Routing Origins
PAGES_ORIGIN=https://tubelinkr.com
API_ORIGIN=https://tubelinkr.com

# Email (Resend)
RESEND_API_KEY=re_...

# ============================================
# FRONTEND (Client-Side - Vite)
# ============================================

# Clerk Authentication (Public Key)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ============================================
# FUTURE / DISABLED
# ============================================

# Referral Worker Secret (Future Implementation)
# This is not currently used. Future implementation will require this for
# Worker-only shared secret to protect referral qualification endpoint.
# REFERRAL_WORKER_SECRET=your-future-worker-secret

