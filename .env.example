# InLinkr Environment Variables Template
# This file documents all required environment variables for local development
# Copy this file to .env and fill in your actual values
# Do not commit .env to version control

# ============================================
# LOCAL DEVELOPMENT (Vite Frontend)
# ============================================

# Clerk Authentication (Public Key - Required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Base URLs (Required)
VITE_REDIRECT_BASE_URL=https://go-dev.inlinkr.com
VITE_APP_BASE_URL=https://app.inlinkr.com
VITE_MARKETING_BASE_URL=https://inlinkr.com

# Feature Flags (Required)
VITE_STRIPE_ENABLED=false
VITE_EMAIL_ENABLED=false
VITE_ENABLE_CUSTOM_SUBDOMAINS=false

# Clerk Auth URLs (Required)
VITE_CLERK_SIGN_IN_URL=/login
VITE_CLERK_SIGN_UP_URL=/signup
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Dev Auth Bypass (Optional - for local development only)
VITE_DEV_AUTH=false
VITE_DEV_AUTH_TOKEN=your_dev_auth_token_here

# ============================================
# LOCAL DEVELOPMENT (Backend Functions)
# ============================================

# Clerk Authentication (Secret Key - Required)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_JWKS_URL=https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json

# Stripe Billing (Optional - set STRIPE_ENABLED=true to use)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
PRO_PRICE_ID_MONTHLY=price_your_pro_monthly_price_id
PRO_PRICE_ID_YEARLY=price_your_pro_yearly_price_id
FOUNDER_PRICE_ID=price_your_founder_price_id

# Email (Resend - Optional - set EMAIL_ENABLED=true to use)
EMAIL_ENABLED=false
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM_NAME=InLinkr
EMAIL_FROM_ADDRESS=notify@inlinkr.com

# Google OAuth (Optional - for YouTube integration)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://app.inlinkr.com/api/youtube/oauth/callback

# Admin Access (Optional)
ADMIN_TEST_KEY=your_secure_random_string
ADMIN_EMAIL_ALLOWLIST=your_email@example.com

# ============================================
# CLOUDFLARE PAGES DEPLOYMENT
# ============================================
# The following variables are configured in wrangler.toml, not .env
# They are listed here for reference only:

# Frontend (Vite) - Set in wrangler.toml [vars] or [env.production]/[env.preview]
# - VITE_CLERK_PUBLISHABLE_KEY
# - VITE_REDIRECT_BASE_URL
# - VITE_APP_BASE_URL
# - VITE_MARKETING_BASE_URL
# - VITE_STRIPE_ENABLED
# - VITE_EMAIL_ENABLED
# - VITE_ENABLE_CUSTOM_SUBDOMAINS
# - VITE_CLERK_SIGN_IN_URL
# - VITE_CLERK_SIGN_UP_URL
# - VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL
# - VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL

# Backend (Functions) - Set in wrangler.toml [vars] or [env.production]/[env.preview]
# - CLERK_SECRET_KEY
# - CLERK_JWKS_URL
# - REDIRECT_BASE_URL
# - APP_BASE_URL
# - MARKETING_BASE_URL
# - EMAIL_ENABLED
# - EMAIL_FROM_NAME
# - EMAIL_FROM_ADDRESS
# - STRIPE_ENABLED
# - STRIPE_SECRET_KEY
# - STRIPE_PUBLISHABLE_KEY
# - STRIPE_WEBHOOK_SECRET
# - PRO_PRICE_ID_MONTHLY
# - PRO_PRICE_ID_YEARLY
# - FOUNDER_PRICE_ID
# - RESEND_API_KEY
# - GOOGLE_OAUTH_CLIENT_ID
# - GOOGLE_OAUTH_CLIENT_SECRET
# - GOOGLE_OAUTH_REDIRECT_URI

# Secrets (Set via Cloudflare Dashboard or wrangler secret command)
# - CLERK_SECRET_KEY (recommended as secret)
# - STRIPE_SECRET_KEY (recommended as secret)
# - STRIPE_WEBHOOK_SECRET (recommended as secret)
# - RESEND_API_KEY (recommended as secret)
# - GOOGLE_OAUTH_CLIENT_SECRET (recommended as secret)

